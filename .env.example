# —— Local (optional) ——
PORT=3789
HOST=0.0.0.0

# Only needed on Windows/dev if Node must go through Clash etc.
# Do NOT set these on Railway unless you run a proxy sidecar.
# HTTPS_PROXY=http://127.0.0.1:7897
# HTTP_PROXY=http://127.0.0.1:7897

# —— Optional data sources ——
# Default: public Robinhood Blockscout (no credit window; may 429 under load).
# BLOCKSCOUT_BASE=https://robinhoodchain.blockscout.com
# EXPLORER_BASE=https://robinhoodchain.blockscout.com
#
# Paid/stable later: Blockscout API gateway (Free tier has credits + 5 req/s —
# too tight for always-on 5s polling; OK when commercial / slower POLL_MS).
# BLOCKSCOUT_BASE=https://api.blockscout.com/4663
# BLOCKSCOUT_API_KEY=
#
# Mint scan interval (ms). 10000 ≈ good enough for hot board; lower = more load.
# POLL_MS=10000
#
# OPENSEA_CHAIN=robinhood
# Required for OpenSea collection meta + minted-out trade volumes (total.volume).
# Free key: https://opensea.io → Developer → API keys. Also set this on Railway Variables.
# OPENSEA_API_KEY=
# CHAIN_ID=4663

# —— Memory / Railway OOM guards ——
# OpenSea full-page HTML scrape is OFF by default (main overnight OOM source).
# REST API covers icon/social when OPENSEA_API_KEY is set. Only enable if you need HTML fallback:
# OPENSEA_HTML_ENABLED=1
# OPENSEA_HTML_MAX_BYTES=524288
# MAX_EVENTS=1500
# RSS_DEGRADE_MB=380

# —— Railway ——
# PORT is injected automatically. Leave HOST default (0.0.0.0).
# No proxy vars required for normal deploy.
#
# Persist ~24h mint events + minted-out + tx prices across restarts/redeploys:
# 1) Railway → service → Volumes → mount e.g. /data
# 2) Variable: DATA_DIR=/data
# Without a Volume, files live only on the ephemeral container FS (wiped on redeploy).
# DATA_DIR=/data
# DISK_EVENT_RETENTION_MS=86400000
# DISK_EVENTS_MAX=8000
# PERSIST_INTERVAL_MS=60000
